# ─────────────────────────────────────────
# TalentIQ .gitignore
# ─────────────────────────────────────────

# ── Environment Variables ─────────────────
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env
frontend/.env.local
ml-service/.env

# ── Node / npm ────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# ── Frontend Build Output ─────────────────
frontend/dist/
frontend/build/
frontend/.vite/

# ── Python ────────────────────────────────
ml-service/venv/
ml-service/__pycache__/
ml-service/*.pyc
ml-service/*.pyo
ml-service/*.pyd
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Python Virtual Environments ───────────
venv/
env/
ENV/
.venv/
.env/

# ── Whisper Model Cache ───────────────────
~/.cache/whisper/
ml-service/.cache/

# ── ML Model Weights ──────────────────────
~/.deepface/
ml-service/weights/
ml-service/models/

# ── Temp Files (ML processing) ────────────
*.wav
*.webm
*.mp4
*.mp3
tmp/
temp/

# ── Logs ──────────────────────────────────
logs/
*.log
backend/logs/
frontend/logs/

# ── OS Files ──────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE / Editor ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
.history/

# ── ngrok ─────────────────────────────────
ngrok.exe
ngrok
*.ngrok*

# ── Misc ──────────────────────────────────
coverage/
.cache/
.turbo/
.vercel/
.netlify/